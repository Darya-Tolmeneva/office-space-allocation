# Copy this file to .env and fill in the values
# cp .env.example .env

# Required: must be a long random string in production
JWT_SIGNING_KEY=dev-only-change-in-production

# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=office_space_allocation

# API server
HTTP_ADDRESS=:8080
# ALLOWED_ORIGINS=https://yourfrontend.example.com
